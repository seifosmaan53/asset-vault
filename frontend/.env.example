# InvoiceMe Frontend Environment Configuration
# Copy this file to .env and update with your actual values

# ============================================
# REQUIRED VARIABLES
# ============================================

# API Base URL (REQUIRED)
# This should point to your backend API endpoint
# Development: http://localhost:3000/api/v1
# Production: https://your-domain.com/api/v1
VITE_API_BASE_URL=http://localhost:3000/api/v1

# ============================================
# PRODUCTION NOTES
# ============================================
# 1. Update VITE_API_BASE_URL to your production backend URL
# 2. Ensure the backend CORS is configured to allow your frontend domain
# 3. Never commit .env file to version control
# 4. After changing .env, restart the development server
