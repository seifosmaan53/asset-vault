{
  "name": "asset-vault-backend",
  "version": "2.0.0",
  "description": "Asset Vault API — NestJS-powered backend for invoice & inventory management",
  "author": "Seif Osman <seifamr5577@gmail.com>",
  "private": true,
  "license": "PROPRIETARY",
  "engines": {
    "node": ">=18.0.0",
    "npm": ">=9.0.0"
  },
  "main": "dist/main.js",
  "types": "dist/main.d.ts",
  "repository": {
    "type": "git",
    "url": "https://github.com/invoiceme/backend.git"
  },
  "keywords": [
    "nestjs",
    "api",
    "invoice",
    "inventory",
    "management"
  ],
  "bugs": {
    "url": "https://github.com/invoiceme/backend/issues"
  },
  "homepage": "https://github.com/invoiceme/backend#readme",
  "files": [
    "dist",
    "src",
    "package.json",
    "README.md"
  ],
  "scripts": {
    "build": "nest build",
    "format": "prettier --write \"src/**/*.ts\" \"test/**/*.ts\"",
    "free-port": "node scripts/free-port.js",
    "start": "nest start",
    "start:dev": "npm run free-port && nest start --watch",
    "start:debug": "npm run free-port && nest start --debug --watch",
    "start:prod": "node dist/main",
    "lint": "eslint \"{src,apps,libs,test}/**/*.ts\" --fix",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:cov": "jest --coverage",
    "test:debug": "node --inspect-brk -r tsconfig-paths/register -r ts-node/register node_modules/.bin/jest --runInBand",
    "test:e2e": "jest --config ./test/jest-e2e.json",
    "seed": "node -r tsconfig-paths/register -r ts-node/register src/database/seed-runner.ts",
    "clear-demo-data": "node -r tsconfig-paths/register -r ts-node/register src/database/clear-demo-data.ts",
    "check-demo-data": "node -r tsconfig-paths/register -r ts-node/register src/database/check-demo-data.ts",
    "diagnose-demo-user": "node -r tsconfig-paths/register -r ts-node/register src/database/diagnose-demo-user.ts",
    "check-current-user": "node -r tsconfig-paths/register -r ts-node/register src/database/check-current-user.ts",
    "verify-user-data-safety": "node -r tsconfig-paths/register -r ts-node/register src/database/verify-user-data-safety.ts",
    "check-user-jwt": "node -r tsconfig-paths/register -r ts-node/register src/database/check-user-jwt.ts",
    "check-user-login": "node -r tsconfig-paths/register -r ts-node/register src/database/check-user-login.ts",
    "migrate-to-organizations": "node -r tsconfig-paths/register -r ts-node/register src/database/migrate-to-organizations.ts",
    "grant-owner": "node -r tsconfig-paths/register -r ts-node/register scripts/grant-owner-access.ts",
    "verify-data": "node -r tsconfig-paths/register -r ts-node/register src/database/verify-data.ts",
    "check-user-data": "node -r tsconfig-paths/register -r ts-node/register src/database/check-user-data.ts",
    "check-deleted-data": "node -r tsconfig-paths/register -r ts-node/register src/database/check-deleted-data.ts",
    "backfill-paid-at": "node -r tsconfig-paths/register -r ts-node/register src/database/backfill-paid-at.ts",
    "add-data-for-user": "node -r tsconfig-paths/register -r ts-node/register src/database/add-data-for-user.ts",
    "list-users": "node -r tsconfig-paths/register -r ts-node/register src/database/list-users.ts",
    "verify-user-data": "node -r tsconfig-paths/register -r ts-node/register src/database/verify-user-data.ts",
    "db:drop": "bash -c 'PGPASSWORD=${DB_PASSWORD:-postgres} dropdb -h ${DB_HOST:-localhost} -p ${DB_PORT:-5432} -U ${DB_USERNAME:-postgres} ${DB_DATABASE:-invoiceme} || echo \"Database may not exist\"'",
    "db:create": "bash -c 'PGPASSWORD=${DB_PASSWORD:-postgres} createdb -h ${DB_HOST:-localhost} -p ${DB_PORT:-5432} -U ${DB_USERNAME:-postgres} ${DB_DATABASE:-invoiceme} || echo \"Database may already exist\"'",
    "migration:run": "node -r tsconfig-paths/register -r ts-node/register src/database/migration-runner.ts",
    "migration:revert": "node -r tsconfig-paths/register -r ts-node/register src/database/migration-revert.ts",
    "migration:generate": "node -r tsconfig-paths/register -r ts-node/register ./node_modules/typeorm/cli.js migration:generate src/migrations/MigrationName -d src/database/data-source.ts",
    "migration:create": "node -r tsconfig-paths/register -r ts-node/register ./node_modules/typeorm/cli.js migration:create src/migrations/MigrationName",
    "db:reset": "npm run db:drop && npm run db:create && npm run migration:run && npm run seed",
    "prepublishOnly": "npm run build",
    "prebuild": "npm run lint",
    "postbuild": "echo Build completed successfully",
    "check:circular": "node scripts/check-circular-deps.js",
    "check:deps": "npm outdated",
    "audit": "npm audit",
    "audit:fix": "npm audit fix"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.965.0",
    "@aws-sdk/s3-request-presigner": "^3.965.0",
    "@clerk/backend": "2.29.0",
    "@nestjs/cache-manager": "3.0.1",
    "@nestjs/common": "11.1.11",
    "@nestjs/config": "^4.0.2",
    "@nestjs/core": "11.1.11",
    "@nestjs/jwt": "11.0.2",
    "@nestjs/passport": "11.0.5",
    "@nestjs/platform-express": "11.1.11",
    "@nestjs/schedule": "6.0.1",
    "@nestjs/swagger": "11.2.3",
    "@nestjs/throttler": "6.5.0",
    "@nestjs/typeorm": "11.0.0",
    "@sendgrid/mail": "^8.1.6",
    "@trpc/server": "^11.8.1",
    "@types/bcryptjs": "2.4.6",
    "@types/compression": "1.8.1",
    "@types/jsonwebtoken": "9.0.10",
    "@types/nodemailer": "7.0.4",
    "@types/passport-jwt": "4.0.1",
    "@types/passport-local": "1.0.38",
    "@types/qrcode": "1.5.6",
    "@types/stripe": "^8.0.417",
    "axios": "^1.13.2",
    "bcryptjs": "3.0.3",
    "body-parser": "1.20.4",
    "cache-manager": "7.2.7",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.3",
    "compression": "1.8.1",
    "cookie-parser": "1.4.7",
    "cors": "2.8.5",
    "date-fns": "4.1.0",
    "exceljs": "4.4.0",
    "express": "4.22.1",
    "helmet": "8.1.0",
    "joi": "18.0.2",
    "jsonwebtoken": "9.0.3",
    "multer": "1.4.5-lts.1",
    "nodemailer": "7.0.11",
    "otplib": "12.0.1",
    "passport": "0.7.0",
    "passport-jwt": "4.0.1",
    "passport-local": "1.0.0",
    "pg": "8.16.3",
    "puppeteer": "24.32.0",
    "qrcode": "1.5.4",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "stripe": "^17.7.0",
    "superjson": "^2.2.6",
    "svix": "1.84.1",
    "swagger-ui-express": "5.0.1",
    "typeorm": "0.3.28",
    "uuid": "10.0.0",
    "validator": "13.15.23",
    "zod": "^4.3.5"
  },
  "devDependencies": {
    "@eslint/js": "9.39.1",
    "@nestjs/cli": "11.0.14",
    "@nestjs/schematics": "11.0.0",
    "@nestjs/testing": "11.1.11",
    "@types/body-parser": "1.19.5",
    "@types/cookie-parser": "1.4.6",
    "@types/cors": "2.8.17",
    "@types/express": "5.0.0",
    "@types/jest": "30.0.0",
    "@types/multer": "2.0.0",
    "@types/node": "24.10.1",
    "@types/supertest": "6.0.2",
    "@types/uuid": "10.0.0",
    "dotenv": "17.2.3",
    "eslint": "9.39.1",
    "eslint-config-prettier": "10.0.1",
    "eslint-plugin-prettier": "5.2.2",
    "globals": "16.5.0",
    "jest": "29.7.0",
    "prettier": "3.4.2",
    "source-map-support": "0.5.21",
    "supertest": "7.1.4",
    "ts-jest": "29.2.5",
    "ts-node": "10.9.2",
    "tsconfig-paths": "4.2.0",
    "typescript": "5.7.3",
    "typescript-eslint": "8.46.4"
  },
  "jest": {
    "moduleFileExtensions": [
      "js",
      "json",
      "ts"
    ],
    "rootDir": "src",
    "testRegex": ".*\\.spec\\.ts$",
    "transform": {
      "^.+\\.(t|j)s$": "ts-jest"
    },
    "collectCoverageFrom": [
      "**/*.(t|j)s"
    ],
    "coverageDirectory": "../coverage",
    "testEnvironment": "node"
  }
}
