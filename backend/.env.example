# InvoiceMe Backend Environment Configuration
# Copy this file to .env and update with your actual values

# ============================================
# REQUIRED VARIABLES
# ============================================

# Database Configuration (REQUIRED)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=invoiceme

# JWT Authentication (REQUIRED)
# Generate strong random secrets for production!
# You can generate secrets using: openssl rand -base64 32
JWT_SECRET=your-secret-key-change-in-production
JWT_EXPIRES_IN=15m
JWT_REFRESH_SECRET=your-refresh-secret-key-change-in-production
JWT_REFRESH_EXPIRES_IN=7d

# ============================================
# OPTIONAL VARIABLES (with defaults)
# ============================================

# Application Configuration
NODE_ENV=development
PORT=3000

# Frontend URL Configuration
# Used for CORS and email links
FRONTEND_URL=http://localhost:5173
FRONTEND_BASE_URL=http://localhost:5173

# ============================================
# OPTIONAL: Email Configuration (SMTP)
# ============================================
# Leave empty if you don't need email functionality
# Email sending will be disabled if not configured
# 
# Example for Gmail:
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=your-email@gmail.com
# SMTP_PASS=your-app-password
# SMTP_FROM="InvoiceMe <no-reply@invoiceme.app>"
#
# Example for SendGrid:
# SMTP_HOST=smtp.sendgrid.net
# SMTP_PORT=587
# SMTP_USER=apikey
# SMTP_PASS=your-sendgrid-api-key
# SMTP_FROM="InvoiceMe <no-reply@invoiceme.app>"
#
# Example for custom SMTP:
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_USER=your-smtp-username
# SMTP_PASS=your-smtp-password
# SMTP_FROM="InvoiceMe <no-reply@yourdomain.com>"

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM="InvoiceMe <no-reply@invoiceme.app>"

# ============================================
# PRODUCTION NOTES
# ============================================
# 1. Change all JWT secrets to strong random values
# 2. Use strong database passwords
# 3. Set NODE_ENV=production
# 4. Update FRONTEND_URL to your production domain
# 5. Configure SMTP for email functionality
# 6. Never commit .env file to version control
